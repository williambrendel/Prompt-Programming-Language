{
  "name": "prompt-programming-language",
  "version": "0.1.0",
  "description": "PPL (Prompt Programming Language) - A structured DSL for LLM prompts with ALL_CAPS sections, indentation-based hierarchy, variables, lists, and code blocks. Convert unstructured text to efficient, anti-hallucination prompts.",
  "main": "src/index.js",
  "bin": {
    "ppl": "./bin/ppl.js"
  },
  "scripts": {
    "clear-all": "rm -rf node_modules/ && npm cache clean --force",
    "docs": "npx documentation build src/**/*.js -f html -o docs",
    "docs:watch": "npx documentation build src/**/*.js -f html -o docs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --silent=false",
    "test:verbose": "NODE_OPTIONS=--experimental-vm-modules jest --verbose --silent=false",
    "update": "npx npm-check-updates -u; npm update; npm install"
  },
  "keywords": [
    "ppl",
    "prompt-programming-language",
    "prompt",
    "llm",
    "dsl",
    "structured-prompt",
    "anti-hallucination",
    "prompt-engineering",
    "validation"
  ],
  "author": "William Brendel",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/williambrendel/Prompt-Programming-Language"
  },
  "homepage": "https://github.com/williambrendel/Prompt-Programming-Language#readme",
  "bugs": {
    "url": "https://github.com/williambrendel/Prompt-Programming-Language/issues"
  },
  "devDependencies": {
    "@eslint/create-config": "latest",
    "@eslint/js": "latest",
    "@jest/globals": "latest",
    "documentation": "^14.0.3",
    "eslint": "latest",
    "eslint-plugin-json": "latest",
    "globals": "latest",
    "jest": "latest",
    "npm-check-updates": "latest"
  }
}